function packBits(buf: Buffer, bitOff: number, bits: number, value: number): void {
    for (let i = 0; i < bits; i++) {
        const byteIdx = Math.floor((bitOff + i) / 8);
        const bitIdx = (bitOff + i) % 8;
        if ((value >>> i) & 1) {
            buf[byteIdx] |= (1 << bitIdx);
        }
    }
}

function unpackBits(buf: Buffer, bitOff: number, bits: number): number {
    let value = 0;
    for (let i = 0; i < bits; i++) {
        const byteIdx = Math.floor((bitOff + i) / 8);
        const bitIdx = (bitOff + i) % 8;
        if ((buf[byteIdx] >>> bitIdx) & 1) {
            value |= (1 << i);
        }
    }
    return value >>> 0;  // ensure unsigned
}

