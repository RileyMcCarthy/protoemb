// ============================================================
// Typed message facade
// ============================================================
// Bridges the generic runtime (raw command id + payload bytes) to typed,
// decoded payloads — the "last mile" so callers don't hand-map ids to structs.

/// A decoded inbound payload (a DATA response or an async notification),
/// tagged with the message it belongs to.
#[derive(Debug, Clone, PartialEq)]
pub enum Inbound {
    {% for name, msg in messages.items() %}
    {% if msg._response_name and msg._command_id is not none %}
    /// DATA response for `{{ name }}` (command {{ msg.command_id }}).
    {{ name | camel_case }}({{ msg._response_name }}),
    {% endif %}
    {% endfor %}
    {% for name, msg in messages.items() %}
    {% if msg._is_async and msg._response_name %}
    /// Async `{{ name }}` notification.
    {{ name | camel_case }}({{ msg._response_name }}),
    {% endif %}
    {% endfor %}
    /// Command not recognized as a DATA producer — raw bytes preserved.
    Unknown { command: u8, payload: Vec<u8> },
}

impl Inbound {
    /// Decode a DATA response for `command` into its typed payload. Unknown
    /// commands and decode failures yield [`Inbound::Unknown`].
    pub fn decode_data(command: u8, payload: &[u8]) -> Self {
        match command {
            {% for name, msg in messages.items() %}
            {% if msg._response_name and msg._command_id is not none %}
            {{ msg.command_id }} => {{ msg._response_name }}::decode(payload)
                .map(Inbound::{{ name | camel_case }})
                .unwrap_or_else(|| Inbound::Unknown { command, payload: payload.to_vec() }),
            {% endif %}
            {% endfor %}
            _ => Inbound::Unknown { command, payload: payload.to_vec() },
        }
    }
    {% for name, msg in messages.items() %}
    {% if msg._is_async and msg._response_name %}

    /// Decode an async `{{ name }}` notification payload into its typed struct.
    pub fn decode_{{ name | snake_case }}(payload: &[u8]) -> Option<{{ msg._response_name }}> {
        {{ msg._response_name }}::decode(payload)
    }
    {% endif %}
    {% endfor %}
}

// ============================================================
// Bit Packing Helpers
// ============================================================

/// Write `bits` bits from `value` into `buf` starting at `bit_off`. LSB-first.
fn pack_bits(buf: &mut [u8], bit_off: u32, bits: u32, value: u32) {
    for i in 0..bits {
        let byte_idx = ((bit_off + i) / 8) as usize;
        let bit_idx = (bit_off + i) % 8;
        if (value >> i) & 1 != 0 {
            buf[byte_idx] |= 1 << bit_idx;
        }
    }
}

/// Read `bits` bits from `buf` starting at `bit_off`. LSB-first. Returns unsigned.
fn unpack_bits(buf: &[u8], bit_off: u32, bits: u32) -> u32 {
    let mut value: u32 = 0;
    for i in 0..bits {
        let byte_idx = ((bit_off + i) / 8) as usize;
        let bit_idx = (bit_off + i) % 8;
        if (buf[byte_idx] >> bit_idx) & 1 != 0 {
            value |= 1 << i;
        }
    }
    value
}

